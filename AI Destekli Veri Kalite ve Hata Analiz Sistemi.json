    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst VALID_SEVERITY = new Set([\"Kritik\", \"Yüksek\", \"Orta\", \"Düşük\"]);\nconst MAX_HATA_TURU = 60;\nconst MAX_COZUM_ONERISI = 120;\n\nconst JUNK_PATTERNS = [\n  /yanıt doldurulmasını/i,\n  /engellemez/i,\n  /oluştuğunuzda/i,\n  /\\. hata/i,\n  /göre,/i,\n  /durumda daha/i,\n  /varsayıldıysa/i,\n  /şekilde kullanın\\.?\\s*e-posta/i\n];\n\nfunction isJunk(text) {\n  if (!text) return true;\n  if (JUNK_PATTERNS.some(p => p.test(text))) return true;\n  if (text.split(/\\s+/).length > 10) return true;\n  return false;\n}\n\nfunction sanitizeText(str, maxLen) {\n  if (!str || typeof str !== \"string\") return \"\";\n  return str.trim()\n    .replace(/\\s+/g, \" \")\n    .replace(/\\.{2,}/g, \".\")\n    .slice(0, maxLen);\n}\n\nfunction buildFallbackSuggestion(errorSummary) {\n  const s = String(errorSummary || \"\").toLowerCase();\n  if (s.includes(\"e-posta\")) return \"E-posta adresini doğrulayıp güncelleyin.\";\n  if (s.includes(\"ad \") || s.includes(\"first_name\")) return \"Müşteri adını eksiksiz girin.\";\n  if (s.includes(\"soyad\") || s.includes(\"last_name\")) return \"Müşteri soyadını eksiksiz girin.\";\n  if (s.includes(\"telefon\")) return \"Telefon numarasını doğru formatta girin.\";\n  if (s.includes(\"şehir\") || s.includes(\"city\")) return \"Şehir alanını doldurun.\";\n  if (s.includes(\"eksik\")) return \"Eksik alanları tamamlayıp kaydı güncelleyin.\";\n  return \"Manuel kontrol gerekli.\";\n}\n\nfunction validateAndFix(obj, severityHint, errorSummary) {\n  const result = {};\n\n  result.hata_turu = sanitizeText(\n    obj.hata_turu || obj[\"hata_türü\"] || obj.error_type || \"\",\n    MAX_HATA_TURU\n  ) || \"Veri hatası\";\n\n  const rawSev = String(obj.ciddiyet || obj.severity || \"\").trim();\n  result.ciddiyet = VALID_SEVERITY.has(rawSev) ? rawSev : (severityHint || \"Yüksek\");\n\n  const aiSuggestion = sanitizeText(\n    obj.cozum_onerisi || obj[\"çözüm_önerisi\"] || obj.solution || obj.cozum || \"\",\n    MAX_COZUM_ONERISI\n  );\n\n  if (aiSuggestion && !isJunk(aiSuggestion)) {\n    result.cozum_onerisi = aiSuggestion;\n    result._suggestion_fallback = false;\n  } else {\n    result.cozum_onerisi = buildFallbackSuggestion(errorSummary);\n    result._suggestion_fallback = true;\n  }\n\n  return result;\n}\n\nfunction parseLayer1(text) {\n  return JSON.parse(text.trim());\n}\n\nfunction parseLayer2(text) {\n  const match = text.match(/\\{[\\s\\S]*?\\}/);\n  if (!match) throw new Error(\"JSON bloğu bulunamadı\");\n  return JSON.parse(match[0]);\n}\n\nfunction parseLayer3(text) {\n  const fieldPatterns = {\n    hata_turu: [\n      /\"hata_t[üu]r[üu]\"\\s*:\\s*\"([^\"]+)\"/i,\n      /hata[_\\s]t[üu]r[üu][:\\s]+([^\\n,}]+)/i\n    ],\n    ciddiyet: [\n      /\"ciddiyet\"\\s*:\\s*\"([^\"]+)\"/i,\n      /ciddiyet[:\\s]+([^\\n,}]+)/i\n    ],\n    cozum_onerisi: [\n      /\"[çc]oz[üu]m[_\\s]?[öo]nerisi\"\\s*:\\s*\"([^\"]+)\"/i,\n      /[çc]oz[üu]m[:\\s]+([^\\n,}]+)/i\n    ]\n  };\n\n  const result = {};\n  for (const [field, patterns] of Object.entries(fieldPatterns)) {\n    for (const pattern of patterns) {\n      const m = text.match(pattern);\n      if (m?.[1]) {\n        result[field] = m[1].trim();\n        break;\n      }\n    }\n  }\n\n  if (!result.hata_turu && !result.ciddiyet && !result.cozum_onerisi) {\n    throw new Error(\"Hiçbir alan bulunamadı\");\n  }\n  return result;\n}\n\nreturn items.map(item => {\n  const rawOutput =\n    item.json?.message?.content ||\n    item.json?.response ||\n    item.json?.text ||\n    \"\";\n\n  const severityHint = item.json?.severity_hint || \"Yüksek\";\n  const errorSummary = item.json?.error_summary || \"\";\n\n  let parsed = null;\n  let parseMethod = \"\";\n  let parseError = \"\";\n\n  const layers = [\n    [\"strict\", () => parseLayer1(rawOutput)],\n    [\"regex\",  () => parseLayer2(rawOutput)],\n    [\"field\",  () => parseLayer3(rawOutput)]\n  ];\n\n  for (const [name, fn] of layers) {\n    try {\n      parsed = fn();\n      parseMethod = name;\n      break;\n    } catch (e) {\n      parseError = e.message;\n    }\n  }\n\n  if (!parsed) {\n    parseMethod = \"fallback\";\n    parsed = {\n      hata_turu: errorSummary.slice(0, MAX_HATA_TURU) || \"Veri hatası\",\n      ciddiyet: severityHint,\n      cozum_onerisi: \"\"\n    };\n  }\n\n  const clean = validateAndFix(parsed, severityHint, errorSummary);\n\n  return {\n    json: {\n      ...item.json,\n      ...clean,\n      _parse_method: parseMethod,\n      _parse_error: parseError\n    }\n  };\n});"
