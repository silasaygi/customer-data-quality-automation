      "parameters": {
        "jsCode": "// n8n Code Node - 1. Kalite Kontrol & Hata Birleştirici\nconst items = $input.all();\n\n// Hata ağırlıkları (yüksek = daha kritik)\nconst ERROR_WEIGHTS = {\n  email: 100,\n  first_name: 80,\n  last_name: 70,\n  phone: 50,\n  city: 30\n};\n\n// Ciddiyet eşikleri (toplam skora göre)\nfunction getSeverityHint(totalScore) {\n  if (totalScore >= 150) return \"Kritik\";\n  if (totalScore >= 100) return \"Yüksek\";\n  if (totalScore >= 50)  return \"Orta\";\n  return \"Düşük\";\n}\n\nreturn items.map(item => {\n  const d = item.json;\n  const errors = [];\n  let totalScore = 0;\n\n  // --- Alan kontrolleri ---\n  if (!d.email || !/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(String(d.email).trim())) {\n    errors.push({ field: \"email\", msg: \"E-posta eksik veya geçersiz format\", weight: ERROR_WEIGHTS.email });\n  }\n  if (!d.first_name || String(d.first_name).trim().length < 2) {\n    errors.push({ field: \"first_name\", msg: \"Ad eksik veya çok kısa\", weight: ERROR_WEIGHTS.first_name });\n  }\n  if (!d.last_name || String(d.last_name).trim().length < 2) {\n    errors.push({ field: \"last_name\", msg: \"Soyad eksik veya çok kısa\", weight: ERROR_WEIGHTS.last_name });\n  }\n  if (d.phone && !/^\\+?[\\d\\s\\-()]{7,15}$/.test(String(d.phone).trim())) {\n    errors.push({ field: \"phone\", msg: \"Telefon formatı geçersiz\", weight: ERROR_WEIGHTS.phone });\n  }\n  if (!d.city || String(d.city).trim().length < 2) {\n    errors.push({ field: \"city\", msg: \"Şehir eksik\", weight: ERROR_WEIGHTS.city });\n  }\n\n  // --- Şüpheli mi? ---\n  const is_suspicious = errors.length > 0;\n\n  if (!is_suspicious) {\n    return { json: { ...d, is_suspicious: false, error_summary: \"\", severity_hint: \"\" } };\n  }\n\n  // --- Önceliğe göre sırala ---\n  errors.sort((a, b) => b.weight - a.weight);\n  totalScore = errors.reduce((sum, e) => sum + e.weight, 0);\n\n  // --- Birleşik özet oluştur ---\n  const primaryError = errors[0].msg;\n  const otherErrors  = errors.slice(1).map(e => e.field).join(\", \");\n  \n  const error_summary = errors.length === 1\n    ? primaryError\n    : `${primaryError}. Ayrıca eksik: ${otherErrors}`;\n\n  // --- Ayrıntılı hata listesi (debugging için) ---\n  const error_reason = errors.map(e => e.msg).join(\" | \");\n\n  return {\n    json: {\n      ...d,\n      is_suspicious,\n      error_reason,\n      error_summary,          // ← Ollama'ya bu gidecek\n      severity_hint: getSeverityHint(totalScore),  // ← Ön tahmin (opsiyonel)\n      error_count: errors.length,\n      error_fields: errors.map(e => e.field)\n    }\n  };\n});"
      },
