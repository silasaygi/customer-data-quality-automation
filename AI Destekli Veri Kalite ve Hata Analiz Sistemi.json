    {
      "parameters": {
        "promptType": "define",
        "text": "=Hata özeti: {{ $json.error_summary }}\n\nYanıt (sadece JSON):",
        "messages": {
          "messageValues": [
            {
              "message": "=Sen bir veri kalitesi botusun. Sadece JSON döndür. Başka hiçbir şey yazma.\n\nÇÖZÜM ÖNERİSİ KURALLARI:\n- Maksimum 8 kelime\n- Eylemle başla: \"Kontrol et\", \"Düzelt\", \"Tamamla\", \"Doğrula\"\n- Tek cümle, nokta ile bitir.\n- Asla şu kalıpları kullanma: \"yanıt doldurulmasını\", \"engellemez\", \"oluştuğunuzda\", \"göre\"\n\nDOĞRU ÖRNEKLER:\nGirdi: \"E-posta eksik veya geçersiz format\"\nÇıktı: {\"hata_turu\":\"Geçersiz e-posta\",\"ciddiyet\":\"Yüksek\",\"cozum_onerisi\":\"E-posta adresini doğrulayıp güncelleyin.\"}\n\nGirdi: \"Ad eksik veya çok kısa\"\nÇıktı: {\"hata_turu\":\"Eksik ad bilgisi\",\"ciddiyet\":\"Yüksek\",\"cozum_onerisi\":\"Müşteri adını eksiksiz girin.\"}\n\nGirdi: \"Şehir eksik\"\nÇıktı: {\"hata_turu\":\"Eksik şehir\",\"ciddiyet\":\"Orta\",\"cozum_onerisi\":\"Şehir alanını doldurun.\"}\n\nGirdi: \"E-posta eksik veya geçersiz format. Ayrıca eksik: first_name, city\"\nÇıktı: {\"hata_turu\":\"Çoklu alan hatası\",\"ciddiyet\":\"Kritik\",\"cozum_onerisi\":\"E-posta, ad ve şehir alanlarını tamamlayın.\"}\n\nFORMAT: {\"hata_turu\":\"...\",\"ciddiyet\":\"...\",\"cozum_onerisi\":\"...\"}\nciddiyet: yalnızca Kritik | Yüksek | Orta | Düşük"
            }
          ]
        },
        "batching": {}
      },
